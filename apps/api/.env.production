# Node 环境：production 里建议开启严格配置
NODE_ENV=production

# MySQL 连接信息
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=12345678
DB_NAME=test-db

# 连接池（生产建议保留默认值并按压测调整）
DB_CONNECTION_LIMIT=10
DB_CONNECT_TIMEOUT_MS=5000

# 查询超时（通过 Promise.race 实现，不依赖 MySQL 端主动取消）
DB_QUERY_TIMEOUT_MS=30000

# 字符集/时区
DB_CHARSET=utf8mb4
DB_TIMEZONE=+00:00

# SSL（可选）
DB_SSL_ENABLED=false
DB_SSL_REJECT_UNAUTHORIZED=false
# DB_SSL_CA_B64=base64_of_ca_pem

